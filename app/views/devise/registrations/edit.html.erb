<%= form_for(resource || current_user, as: :user, url: registration_path(current_user), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource || current_user %>

  <%= render 'layouts/settings_nav', current_page: :profile %>

  <h2><%= title 'Profile' %></h2>

  <p>
    Fill in your
    <%= ENV.fetch('SITE_TITLE', 'LandGrab') %>
    profile; who are you?
  </p>

  <%= render 'users/form_names', form: f %>

  <%= render 'users/form_email', form: f %>

  <%= render 'users/form_username', form: f %>

  <%= render 'users/form_website', form: f %>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <div>Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
  <% end %>

  <%= f.submit 'Update Profile', class: 'btn btn-primary' %>
<% end %>

<hr>

<h3>Referral link</h3>
<p class="text-muted">Share this link with friends. When they register using it, they'll be associated with your account.</p>
<%= render 'layouts/copy_to_clipboard',
           copytext: referral_url(referral_token: current_user.referral_token),
           copycta: 'Copy referral link' %>
