<%= form_with(model: [:admin, user], local: true) do |form| %>
  <%= render 'layouts/form_errors', errors: user.errors %>

  <div class="row mb-3 g-3 align-items-center">
    <div class="col-sm-2">
      <%= form.label :first_name, class: 'col-form-label' %>
    </div>
    <div class="col-sm-3">
      <%= form.text_field :first_name, required: true, class: 'form-control', aria: { describedby: 'firstNameHelp' } %>
    </div>
    <div class="col-sm-7">
      <span id="firstNameHelp" class="form-text">
        Enter the forename of the user.
      </span>
    </div>
  </div>

  <div class="row mb-3 g-3 align-items-center">
    <div class="col-sm-2">
      <%= form.label :last_name, class: 'col-form-label' %>
    </div>
    <div class="col-sm-3">
      <%= form.text_field :last_name, required: true, class: 'form-control', aria: { describedby: 'lastNameHelp' } %>
    </div>
    <div class="col-sm-7">
      <span id="lastNameHelp" class="form-text">
        Enter the surname of the user.
      </span>
    </div>
  </div>

  <div class="row mb-3 g-3 align-items-center">
    <div class="col-sm-2">
      <%= form.label :username, class: 'col-form-label' %>
    </div>
    <div class="col-sm-3">
      <%= form.text_field :username, class: 'form-control', aria: { describedby: 'usernameHelp' } %>
    </div>
    <div class="col-sm-7">
      <span id="usernameHelp" class="form-text">
        Optional. Sets the user's public profile URL (/users/username).
      </span>
    </div>
  </div>

  <div class="row mb-3 g-3 align-items-center">
    <div class="col-sm-2">
      <%= form.label :website_url, class: 'col-form-label' %>
    </div>
    <div class="col-sm-3">
      <%= form.url_field :website_url, class: 'form-control', aria: { describedby: 'websiteUrlHelp' } %>
    </div>
    <div class="col-sm-7">
      <span id="websiteUrlHelp" class="form-text">
        Optional personal website URL (must start with http:// or https://).
      </span>
    </div>
  </div>

  <div class="row mb-3 g-3 align-items-center">
    <div class="col-sm-2">
      <%= form.label :website_title, class: 'col-form-label' %>
    </div>
    <div class="col-sm-3">
      <%= form.text_field :website_title, class: 'form-control', aria: { describedby: 'websiteTitleHelp' } %>
    </div>
    <div class="col-sm-7">
      <span id="websiteTitleHelp" class="form-text">
        Optional. Link text displayed on the profile (defaults to "Personal website").
      </span>
    </div>
  </div>

  <div class="row mb-3 g-3 align-items-center">
    <div class="col-sm-2">
      <%= form.label :team_id, class: 'col-form-label' %>
    </div>
    <div class="col-sm-3">
      <%= form.collection_select :team_id, Team.order(:title), :id, :title, { include_blank: '[ No team ]' }, { class: 'form-control', aria: { describedby: 'teamHelp' } } %>
    </div>
    <div class="col-sm-7">
      <span id="teamHelp" class="form-text">
        Associate the user with a team.
      </span>
    </div>
  </div>

  <%= form.submit class: 'btn btn-primary' %>
<% end %>
