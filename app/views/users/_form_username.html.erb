<div class="mb-3">
  <%= form.label :username, class: 'form-label' %>
  <div class="input-group">
    <span class="input-group-text">@</span>
    <%= form.text_field :username, autocomplete: 'username', class: 'form-control', placeholder: 'your_username' %>
  </div>
  <div class="form-text">Optional. Sets your public profile URL: /users/your_username. Letters, numbers, and underscores only (3–30 characters).</div>
</div>
